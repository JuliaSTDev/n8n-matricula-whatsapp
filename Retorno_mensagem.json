    {
      "parameters": {
        "jsCode": "\nconst raw = ($json.text || $json.output || '').trim().replace(/```json|```/g, '').trim();\nconst input = $('When Executed by Another Workflow').item.json;\n\nlet tem_data = false;\nlet data_local = null;\nlet data_legivel = null;\n\ntry {\n  const parsed = JSON.parse(raw);\n  tem_data = parsed.tem_data === true;\n\n  if (tem_data && parsed.data_formatada) {\n    data_local = parsed.data_formatada; // ex: \"2026-06-09 14:10:00\" em horário de Brasília\n    const partes = parsed.data_formatada.split(' ');\n    const [ano, mes, dia] = partes[0].split('-');\n    const hora = partes[1] ? partes[1].substring(0, 5) : '09:00';\n    data_legivel = `${dia}/${mes}/${ano} às ${hora}`;\n  }\n} catch(e) {}\n\nreturn [{ json: { ...input, tem_data, data_local, data_legivel } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
